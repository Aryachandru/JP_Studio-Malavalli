rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Gallery photos (Wedding, Pre Wedding, Baby Shoot, Birthday, Maternity
    // subfolders) — publicly viewable, only the signed-in admin can
    // upload or delete.
    match /gallery/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
